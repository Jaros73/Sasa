@page "/{kultura:regex(^cs|en|de$)?}"
@model IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<Sasa.SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["PageTitle"];
}

<section id="uvod" class="hero-section">
    <div class="hero-overlay">
        <div class="container hero-content">
            <p class="hero-kicker">@Localizer["HeroKicker"]</p>
            <h1>@Localizer["HeroTitle"]</h1>
            <p class="hero-text">
                @Localizer["HeroText"]
            </p>
            <div class="hero-actions">
                <a class="button button-primary" href="#ubytovani">@Localizer["HeroButtonMore"]</a>
                <a class="button button-secondary" href="#kontakt">@Localizer["HeroButtonContact"]</a>
            </div>
        </div>
    </div>
</section>

<section class="content-section section-light">
    <div class="container narrow">
        <div class="section-heading">
            <h2>@Localizer["IntroHeading"]</h2>
        </div>

        <div class="text-card">
            <p>@Localizer["IntroParagraph1"]</p>
            <p>@Localizer["IntroParagraph2"]</p>
            <p>@Localizer["IntroParagraph3"]</p>
            <p>@Localizer["IntroParagraph4"]</p>
            <p>@Localizer["IntroParagraph5"]</p>
        </div>
    </div>
</section>

<section id="ubytovani" class="content-section section-light">
    <div class="container narrow">
        <div class="section-heading">
            <h2>@Localizer["AccommodationHeading"]</h2>
        </div>

        <div class="text-card">
            <p>@Localizer["AccommodationParagraph1"]</p>
            <p>@Localizer["AccommodationParagraph2"]</p>
            <p>
                @Localizer["AccommodationParagraph3Part1"]
                <strong>@Localizer["AccommodationNoSmoking"]</strong>,
                @Localizer["AccommodationParagraph3Part2"]
                <strong>@Localizer["AccommodationIndoorShoes"]</strong>.
                @Localizer["AccommodationParagraph3Part3"]
            </p>
        </div>

        <div class="gallery-grid gallery-ubytovani">
            <div class="gallery-item"><img src="~/images/gallery/galerie-01.jpg" alt="@Localizer["AccommodationImage1Alt"]" /></div>
            <div class="gallery-item"><img src="~/images/gallery/galerie-02.jpg" alt="@Localizer["AccommodationImage2Alt"]" /></div>
            <div class="gallery-item"><img src="~/images/gallery/galerie-03.jpg" alt="@Localizer["AccommodationImage3Alt"]" /></div>
            <div class="gallery-item"><img src="~/images/gallery/galerie-04.jpg" alt="@Localizer["AccommodationImage4Alt"]" /></div>
        </div>
    </div>
</section>

<section id="cenik" class="content-section section-accent">
    <div class="container narrow">
        <div class="section-heading">
            <h2>@Localizer["PriceHeading"]</h2>
            <p>@Localizer["PriceValidFrom"]</p>
        </div>

        <div class="price-card">
            <p>@Localizer["PriceIntroParagraph1"]</p>
            <p>
                @Localizer["PriceIntroParagraph2Part1"]
                <strong>@Localizer["CheckInTime"]</strong>,
                @Localizer["PriceIntroParagraph2Part2"]
                <strong>@Localizer["CheckOutTime"]</strong>
            </p>

            <div class="price-table-wrapper">
                <table class="price-table">
                    <thead>
                        <tr>
                            <th>@Localizer["PriceTableService"]</th>
                            <th>@Localizer["PriceTableCurrency"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>@Localizer["PriceAdult"]</td>
                            <td>@Localizer["PriceAdultValue"]</td>
                        </tr>
                        <tr>
                            <td>@Localizer["PriceChildUnder3"]</td>
                            <td>@Localizer["PriceChildUnder3Value"]</td>
                        </tr>
                        <tr>
                            <td>@Localizer["PriceChildUnder12"]</td>
                            <td>@Localizer["PriceChildUnder12Value"]</td>
                        </tr>
                        <tr>
                            <td>@Localizer["PriceSingleOccupancy"]</td>
                            <td>@Localizer["PriceSingleOccupancyValue"]</td>
                        </tr>
                        <tr>
                            <td>@Localizer["PriceOneNightOnly"]</td>
                            <td>@Localizer["PriceOneNightOnlyValue"]</td>
                        </tr>
                        <tr>
                            <td>@Localizer["PricePet"]</td>
                            <td>@Localizer["PricePetValue"]</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <h3>@Localizer["EasterHeading"]</h3>

            <div class="price-table-wrapper">
                <table class="price-table">
                    <thead>
                        <tr>
                            <th>@Localizer["PriceTableService"]</th>
                            <th>@Localizer["PriceTableCurrency"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>@Localizer["PriceAdult"]</td>
                            <td>@Localizer["EasterAdultValue"]</td>
                        </tr>
                        <tr>
                            <td>@Localizer["PriceChildUnder3"]</td>
                            <td>@Localizer["PriceChildUnder3Value"]</td>
                        </tr>
                        <tr>
                            <td>@Localizer["PriceChildUnder12"]</td>
                            <td>@Localizer["EasterChildUnder12Value"]</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <h3>@Localizer["ChristmasHeading"]</h3>

            <div class="price-table-wrapper">
                <table class="price-table">
                    <thead>
                        <tr>
                            <th>@Localizer["PriceTableService"]</th>
                            <th>@Localizer["PriceTableCurrency"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>@Localizer["PriceAdult"]</td>
                            <td>@Localizer["ChristmasAdultValue"]</td>
                        </tr>
                        <tr>
                            <td>@Localizer["PriceChildUnder3"]</td>
                            <td>@Localizer["PriceChildUnder3Value"]</td>
                        </tr>
                        <tr>
                            <td>@Localizer["PriceChildUnder12"]</td>
                            <td>@Localizer["ChristmasChildUnder12Value"]</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <p>
                <strong>@Localizer["ClosedNotice"]</strong>
            </p>

            <p>
                @Localizer["LocalFeeParagraphPart1"]
                <strong>@Localizer["LocalFeeValue"]</strong>
                @Localizer["LocalFeeParagraphPart2"]
            </p>

            <h3>@Localizer["OrdersAndDepositHeading"]</h3>
            <p>@Localizer["OrdersParagraph"]</p>

            <h3>@Localizer["DepositHeading"]</h3>
            <p>@Localizer["DepositParagraph"]</p>

            <h3>@Localizer["CancellationHeading"]</h3>
            <div class="price-table-wrapper">
                <table class="price-table">
                    <tbody>
                        <tr>
                            <td>@Localizer["CancellationRow1Label"]</td>
                            <td>@Localizer["CancellationRow1Value"]</td>
                        </tr>
                        <tr>
                            <td>@Localizer["CancellationRow2Label"]</td>
                            <td>@Localizer["CancellationRow2Value"]</td>
                        </tr>
                        <tr>
                            <td>@Localizer["CancellationRow3Label"]</td>
                            <td>@Localizer["CancellationRow3Value"]</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <p>@Localizer["CancellationParagraph"]</p>

            <h3>@Localizer["PersonalDataHeading"]</h3>
            <p>@Localizer["PersonalDataParagraph"]</p>
        </div>
    </div>
</section>

<section id="galerie" class="content-section section-light">
    <div class="container">
        <div class="section-heading">
            <h2>@Localizer["GalleryHeading"]</h2>
        </div>

        <div class="gallery-grid">
            <div class="gallery-item"><img src="~/images/gallery/galerie-01.jpg" alt="@Localizer["GalleryImage1Alt"]" /></div>
            <div class="gallery-item"><img src="~/images/gallery/galerie-02.jpg" alt="@Localizer["GalleryImage2Alt"]" /></div>
            <div class="gallery-item"><img src="~/images/gallery/galerie-03.jpg" alt="@Localizer["GalleryImage3Alt"]" /></div>
            <div class="gallery-item"><img src="~/images/gallery/galerie-04.jpg" alt="@Localizer["GalleryImage4Alt"]" /></div>
            <div class="gallery-item"><img src="~/images/gallery/galerie-05.jpg" alt="@Localizer["GalleryImage5Alt"]" /></div>
            <div class="gallery-item"><img src="~/images/gallery/galerie-06.jpg" alt="@Localizer["GalleryImage6Alt"]" /></div>
            <div class="gallery-item"><img src="~/images/gallery/galerie-07.jpg" alt="@Localizer["GalleryImage7Alt"]" /></div>
            <div class="gallery-item"><img src="~/images/gallery/galerie-08.jpg" alt="@Localizer["GalleryImage8Alt"]" /></div>
            <div class="gallery-item"><img src="~/images/gallery/galerie-09.jpg" alt="@Localizer["GalleryImage9Alt"]" /></div>
            <div class="gallery-item"><img src="~/images/gallery/galerie-10.jpg" alt="@Localizer["GalleryImage10Alt"]" /></div>
            <div class="gallery-item"><img src="~/images/gallery/galerie-11.jpg" alt="@Localizer["GalleryImage11Alt"]" /></div>
            <div class="gallery-item"><img src="~/images/gallery/galerie-12.jpg" alt="@Localizer["GalleryImage12Alt"]" /></div>
            <div class="gallery-item"><img src="~/images/gallery/galerie-13.jpg" alt="@Localizer["GalleryImage13Alt"]" /></div>
            <div class="gallery-item"><img src="~/images/gallery/galerie-14.jpg" alt="@Localizer["GalleryImage14Alt"]" /></div>
        </div>
    </div>
</section>

<section id="kontakt" class="content-section section-light">
    <div class="container narrow">
        <div class="contact-box">
            <h3 class="contact-title-main">
                @Localizer["ContactHeading"]
            </h3>

            <div class="contact-columns">
                <div class="contact-left">
                    @Localizer["ContactNameLine"]<br />
                    @Localizer["ContactAddressLine"]
                </div>

                <div class="contact-right">
                    <div class="contact-row">
                        <span>@Localizer["ContactIcoLabel"]</span>
                        <strong>23145820</strong>
                    </div>

                    <div class="contact-row">
                        <span>@Localizer["ContactMobileLabel"]</span>
                        <strong><a href="tel:+420728610426">728 610 426</a></strong>
                    </div>

                    <div class="contact-row">
                        <span>@Localizer["ContactBankLabel"]</span>
                        <strong>315 123 5003 / 0800</strong>
                    </div>

                    <div class="contact-row">
                        <span>@Localizer["ContactEmailLabel"]</span>
                        <strong>
                            <a href="mailto:ukotoru@ukotoru.cz">ukotoru@ukotoru.cz</a>
                        </strong>
                    </div>

                    <div class="contact-links">
                        <a class="fb-link"
                               href="https://www.facebook.com/HorskaKvildaUKotoru/"
                               target="_blank"
                               rel="noopener noreferrer">
                            @Localizer["FacebookLink"]
                        </a>

                        <a class="fb-share"
                               href="https://www.facebook.com/sharer/sharer.php?u=https://ukotoru.cz"
                               target="_blank"
                               rel="noopener noreferrer">
                            @Localizer["FacebookShare"]
                        </a>
                    </div>
                </div>
            </div>

            <div class="map-wrapper map-inside">
                <div id="map"></div>
            </div>

            <p class="contact-note">
                <strong>@Localizer["ContactNote"]</strong>
            </p>
        </div>
    </div>
</section>