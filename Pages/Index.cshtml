            <div class="price-table-wrapper">
                <table class="price-table">
                    <thead>
                        <tr>
                            <th>Služba</th>
                            <th>Kč</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Dospělý, dítě nad 12 let</td>
                            <td>700 / noc</td>
                        </tr>
                        <tr>
