<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - U Kotorů</title>
    <meta name="description" content="Ubytování na Šumavě. Přehled ubytování, ceník, galerie a kontakt." />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
</head>
<body>
    <header class="site-header">
        <div class="container header-inner">
            <a class="site-logo" href="#uvod">U Kotorů</a>

            <button class="menu-toggle"
                    type="button"
                    aria-label="Otevřít menu"
                    aria-expanded="false"
                    aria-controls="site-nav">
                <span class="menu-toggle-line"></span>
                <span class="menu-toggle-line"></span>
                <span class="menu-toggle-line"></span>
            </button>

            <nav id="site-nav" class="site-nav" aria-label="Hlavní navigace">
                <a href="#uvod">Úvod</a>
                <a href="#ubytovani">Ubytování</a>
                <a href="#cenik">Ceník</a>
                <a href="#galerie">Galerie</a>
                <a href="#kontakt">Kontakt</a>
            </nav>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container footer-inner">
            <p>&copy; @DateTime.Now.Year U Kotorů. Všechna práva vyhrazena.</p>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>