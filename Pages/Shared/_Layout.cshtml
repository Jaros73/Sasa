@using System.Globalization
@{
    var aktualniKultura = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var baseUrl = "https://test.ukotoru.cz";

    var canonicalUrl = $"{baseUrl}/{aktualniKultura}";
    var csUrl = $"{baseUrl}/cs";
    var enUrl = $"{baseUrl}/en";
    var deUrl = $"{baseUrl}/de";
}
@inject Microsoft.Extensions.Localization.IStringLocalizer<Sasa.SharedResource> Localizer
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - U Kotorů</title>
    <link rel="canonical" href="@canonicalUrl" />

    <link rel="alternate" hreflang="cs" href="@csUrl" />
    <link rel="alternate" hreflang="en" href="@enUrl" />
    <link rel="alternate" hreflang="de" href="@deUrl" />
    <link rel="alternate" hreflang="x-default" href="@csUrl" />

    <meta name="description" content="Ubytování na Šumavě. Přehled ubytování, ceník, galerie a kontakt." />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
</head>
<body>
    <header class="site-header">
        <div class="container header-inner">
            <a class="site-logo" href="#uvod">U Kotorů</a>

            <button class="menu-toggle"
                    type="button"
                    aria-label="Otevřít menu"
                    aria-expanded="false"
                    aria-controls="site-nav">
                <span class="menu-toggle-line"></span>
                <span class="menu-toggle-line"></span>
                <span class="menu-toggle-line"></span>
            </button>

            <nav id="site-nav" class="site-nav" aria-label="Hlavní navigace">
                <a href="#uvod">@Localizer["NavIntro"]</a>
                <a href="#ubytovani">@Localizer["NavAccommodation"]</a>
                <a href="#cenik">@Localizer["NavPriceList"]</a>
                <a href="#galerie">@Localizer["NavGallery"]</a>
                <a href="#kontakt">@Localizer["NavContact"]</a>
            </nav>
            <div class="lang-switch">
                <a href="/cs"
                   class="lang-btn @(aktualniKultura == "cs" ? "active" : "")">CZ</a>

                <a href="/en"
                   class="lang-btn @(aktualniKultura == "en" ? "active" : "")">GB</a>

                <a href="/de"
                   class="lang-btn @(aktualniKultura == "de" ? "active" : "")">DE</a>
            </div>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container footer-inner">
            <p>&copy; @DateTime.Now.Year U Kotorů. Všechna práva vyhrazena.</p>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>