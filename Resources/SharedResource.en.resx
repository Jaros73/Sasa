  <data name="PriceValidFrom" xml:space="preserve"><value>Price list valid from January 1, 2026</value></data>
  <data name="PriceIntroParagraph1" xml:space="preserve"><value>Summer and winter stays are usually weekly (Saturday to Saturday). Outside the main summer and winter seasons, shorter stays may also be arranged.</value></data>
  <data name="PriceIntroParagraph2Part1" xml:space="preserve"><value>Check-in is available</value></data>
  <data name="CheckInTime" xml:space="preserve"><value>from 3:30 PM to 7:30 PM</value></data>
  <data name="PriceIntroParagraph2Part2" xml:space="preserve"><value>and rooms must be vacated</value></data>
  <data name="CheckOutTime" xml:space="preserve"><value>by 10:00 AM</value></data>

